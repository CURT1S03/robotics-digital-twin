# Copy this file to .env and fill in your paths.

# ── Isaac paths ────────────────────────────────────────────────────────────── #
ISAACSIM_PATH=A:\Projects\IsaacSim\isaac-sim-standalone-5.1.0-windows-x86_64
ISAACLAB_PATH=A:\Projects\IsaacLab

# ── Conda env that has Isaac Lab installed ─────────────────────────────────── #
CONDA_ENV_NAME=env_isaaclab

# ── Database (defaults to logs/digital_twin.db if not set) ────────────────── #
# DATABASE_URL=sqlite+aiosqlite:///logs/digital_twin.db

# ── Backend server ─────────────────────────────────────────────────────────── #
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Simulation defaults ────────────────────────────────────────────────────── #
DEFAULT_MAX_STEPS=2000
DEFAULT_NUM_TRIALS=3

# ── Mock ROS 2 topic prefix ────────────────────────────────────────────────── #
ROS_TOPIC_PREFIX=/dt
